library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.STD_LOGIC_ARITH.ALL;
use IEEE.STD_LOGIC_UNSIGNED.ALL;

entity CtrlUnit is
  port(
    Oper         : in  STD_LOGIC_VECTOR (3 downto 0); -- Opcode de la instrucción (entrada de 4 bits)
    RegSrc_Op    : out STD_LOGIC_VECTOR (1 downto 0); -- Selección de dato para registro (C09)
    ALUOp_Op     : out STD_LOGIC_VECTOR (2 downto 0); -- Operación para la ALU (C05)
    RegWrite_Op  : out STD_LOGIC;                    -- Habilitar escritura en registros (C04)
    Write7Seg_Op : out STD_LOGIC;                    -- Habilitar registro 7-Seg (C11)
    WriteLEDs_Op : out STD_LOGIC;                    -- Habilitar registro LEDs (C12)
    PCInc_Op     : out STD_LOGIC;                    -- Salto relativo (C07)
    Beq_Op       : out STD_LOGIC;                    -- Indicador de instrucción BEQ
    JiJr_Op      : out STD_LOGIC_VECTOR (1 downto 0) -- Selección de salto PC (C08)
  );
end CtrlUnit;

architecture Behavioral of CtrlUnit is
begin
    process(Oper)
    begin
        -- Valores por defecto (Estado inactivo/seguro)
        RegSrc_Op    <= "00"; 
        ALUOp_Op     <= "000"; 
        RegWrite_Op  <= '0';
        Write7Seg_Op <= '0';  
        WriteLEDs_Op <= '0'; 
        PCInc_Op     <= '0';
        Beq_Op       <= '0';  
        JiJr_Op      <= "00";

        case Oper is
            -- 1. ADD: rd = rs + rt
            when "0000" => 
                RegWrite_Op <= '1'; ALUOp_Op <= "000"; RegSrc_Op <= "00";

            -- 2. SUB: rd = rs - rt
            when "0001" => 
                RegWrite_Op <= '1'; ALUOp_Op <= "001"; RegSrc_Op <= "00";

            -- 3. AND: rd = rs AND rt
            when "0010" => 
                RegWrite_Op <= '1'; ALUOp_Op <= "010"; RegSrc_Op <= "00";

            -- 4. OR: rd = rs OR rt
            when "0011" => 
                RegWrite_Op <= '1'; ALUOp_Op <= "011"; RegSrc_Op <= "00";

            -- 5. XOR: rd = rs XOR rt
            when "0100" => 
                RegWrite_Op <= '1'; ALUOp_Op <= "100"; RegSrc_Op <= "00";

            -- 6. NOT: rd = NOT rs
            when "0101" => 
                RegWrite_Op <= '1'; ALUOp_Op <= "101"; RegSrc_Op <= "00";

            -- 7. SHL: rd = rs << 1 (Multiplicar x2)
            when "0110" => 
                RegWrite_Op <= '1'; ALUOp_Op <= "110"; RegSrc_Op <= "00";

            -- 8. SHR: rd = rs >> 1 (Dividir /2)
            when "0111" => 
                RegWrite_Op <= '1'; ALUOp_Op <= "111"; RegSrc_Op <= "00";
            
            -- 9. LD: rd = inmediato
            when "1000" => 
                RegWrite_Op <= '1'; RegSrc_Op <= "01";

            -- 10. SPC: rd = PC
            when "1001" => 
                RegWrite_Op <= '1'; RegSrc_Op <= "10";
            
            -- 11. BEQ: if rs == rt then PC = PC + 1 + imm
            when "1010" => 
                Beq_Op <= '1'; PCInc_Op <= '1'; ALUOp_Op <= "001"; -- Resta para comparar

            -- 12. JI: PC = inmediato
            when "1011" => 
                JiJr_Op <= "01";

            -- 13. JR: PC = rs
            when "1100" => 
                JiJr_Op <= "10";
            
            -- 14. W7SEG: Display = rs
            when "1101" => 
                Write7Seg_Op <= '1';

            -- 15. WLEDS: LEDs = rs
            when "1110" => 
                WriteLEDs_Op <= '1';
                
            when others => null;
        end case;
    end process;
end Behavioral;
